{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": [
    "**/*.ts",
    "abis/simulationRegistry_abi.js",
    "abis/simulationJobQueue_abi.js"
  ],
  "exclude": ["node_modules", "dist"]
}
