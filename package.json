{
  "name": "defi-strategy-profiler",
  "version": "1.0.0",
  "private": true,
  "description": "DeFi Strategy Profiler using Chainlink CRE and Tenderly Virtual TestNets to simulate strategies and store signed on-chain reports.",
  "author": "Mohd Muzammil <github.com/0xEunum>",
  "workspaces": [
    "cre",
    "frontend",
    "cli",
    "contracts"
  ],
  "scripts": {
    "cli:setup": "npm run setup --workspace=cli",
    "cli:setup:new": "npm run setup:new --workspace=cli",
    "cli:deploy:0": "npm run deploy:0 --workspace=cli",
    "cli:deploy:1": "npm run deploy:1 --workspace=cli",
    "cli:deploy:2": "npm run deploy:2 --workspace=cli",
    "cli:provision:0": "npm run provision:0 --workspace=cli",
    "cli:provision:1": "npm run provision:1 --workspace=cli",
    "cli:provision:2": "npm run provision:2 --workspace=cli",
    "cre:listener": "npm run listener --workspace=cre",
    "cre:executor": "npm run executor --workspace=cre",
    "frontend:dev": "npm run dev --workspace=frontend",
    "frontend:build": "npm run build --workspace=frontend",
    "frontend:preview": "npm run preview --workspace=frontend"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "chainlink",
    "cre",
    "tenderly",
    "defi",
    "simulation",
    "strategy-profiler"
  ]
}