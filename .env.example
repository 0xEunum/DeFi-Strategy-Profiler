###############################################################################
### REQUIRED ENVIRONMENT VARIABLES                                          ###
### DO NOT COMMIT OR SHARE THIS FILE                                        ###
###############################################################################


# ── CRE Target ───────────────────────────────────────────────────────────────
# Which settings block in cre/project.yaml to use
# Options: staging-settings | production-settings
CRE_TARGET=staging-settings


# ── CRE Forwarder ─────────────────────────────────────────────────────────────
# Chainlink CRE forwarder contract on Sepolia — used by writeReport()
# Full directory: https://docs.chain.link/cre/guides/workflow/using-evm-client/forwarder-directory-ts
# ⚠️  Only change this if Chainlink deploys a new forwarder on Sepolia
SIM_SEPOLIA_FORWARDER=0x15fC6ae953E024d975e77382eEeC56A9101f9F88


# ── Dev Wallet ───────────────────────────────────────────────────────────────
# Your EOA private key (no 0x prefix)
# Used ONLY for: requestSimulation() call on Sepolia
# ✅ vNet deployment uses unlocked vNet accounts — this key never touches the vNet
CRE_ETH_PRIVATE_KEY=


# ── Sepolia RPC ───────────────────────────────────────────────────────────────
# Public Sepolia RPC for contract reads/writes (requestSimulation, pollForReport)
# Replace with your own Alchemy/Infura endpoint for better reliability
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com


# ── Sepolia Contracts ─────────────────────────────────────────────────────────
# Default: shared deployed contracts — works out of the box, no changes needed
#
# 🔧 Custom deployment (optional):
#   If you want your own registry + job queue:
#   1. Run: cd contracts && forge script script/DeploySepolia.s.sol --broadcast
#   2. Update REGISTRY_ADDRESS and JOB_QUEUE_ADDRESS below
#   3. Update registryAddress and jobQueueAddress in cre/config.staging.json
REGISTRY_ADDRESS=0x6C60a2dEbD7a0406fB08133c44FC0bAeB2424e7d
JOB_QUEUE_ADDRESS=0x9E3EA28542fD36B062ac768037fFb93708529Ad1


# ── Tenderly Credentials ──────────────────────────────────────────────────────
# Required for creating and managing Tenderly Virtual TestNets
# Get these from: https://dashboard.tenderly.co → Settings → Authorization
TENDERLY_ACCESS_KEY=
TENDERLY_ACCOUNT_SLUG=
TENDERLY_PROJECT_SLUG=


# ── Tenderly vNet Admin RPC ───────────────────────────────────────────────────
# 🤖 AUTO-FILLED by: npm run setup  (or any npm run provision:*)
# Do not edit manually — always run npm run setup to regenerate
# Used by: wf-executor workflow to send transactions on the vNet
VNET_ADMIN_RPC_URL=


# ── Optional ──────────────────────────────────────────────────────────────────
VNET_FUND_ETH=10       # ETH amount to fund each vNet account on creation
POLL_FOR_RESULT=true   # Set true to auto-poll terminal for simulation result
